# ─────────────────────────────────────────────────────────────
#  Lumina Studio — environment configuration
#  Copy this file to `.env.local` and fill in your keys.
#  These values stay server-side and are never sent to the browser.
# ─────────────────────────────────────────────────────────────

# === Nano Banana Pro (Google Gemini API) — IMAGE generation ===
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Model id for Nano Banana Pro (Gemini 3 Pro Image). The provider auto-falls
# back to the `-preview` id if your key only exposes the preview model.
GEMINI_IMAGE_MODEL=gemini-3-pro-image

# === Seedance (BytePlus ModelArk) — VIDEO generation ===
# Get a key: https://console.byteplus.com/ark  (ModelArk -> API Keys)
ARK_API_KEY=
# Region base URL. Common: ap-southeast (Singapore). Adjust to your region.
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# Seedance 2.0 model ids (2.0 is required for reference-to-video / @img tagging).
# Standard = 1080p; Fast (used for "Seedance 2.0 Mini" in the UI) = 720p.
SEEDANCE_MODEL=dreamina-seedance-2-0-260128
SEEDANCE_MODEL_FAST=dreamina-seedance-2-0-fast-260128
# Role sent with @img reference images (subject/character locking).
# Set to "first_frame" only if you want single-image image-to-video instead.
SEEDANCE_IMAGE_ROLE=reference_image

# === Higgsfield (via official MCP) — Soul image + Seedance 2.0 multi-image video ===
# Auth is a one-time browser login (no API key): run `npm run hf:login`, which
# writes .higgsfield-mcp-token.json (used in local dev, auto-refreshed).
# For HOSTING (read-only filesystem), copy the refresh_token + client_id from
# that file into these env vars instead:
HIGGSFIELD_MCP_REFRESH_TOKEN=
HIGGSFIELD_MCP_CLIENT_ID=

# === Gemini Omni Flash (Interactions API) — VIDEO generation ===
# Default wire path reuses GOOGLE_API_KEY above (proven to reach Omni; paid-
# tier usage bills to that key's GCP project). No separate key needed.
# Model id override (rarely needed).
# OMNI_MODEL=gemini-omni-flash-preview
# Set to "1" to bill on the Vertex AI SKU instead (user asked for GCP-credit
# billing). Requires OAuth2 creds — GOOGLE_APPLICATION_CREDENTIALS (service
# account JSON) or `gcloud auth application-default login` — AND a GCP
# project. Public reports say Vertex access to Omni is allowlist-gated as of
# 2026-07; request access for your project if you get a 403.
# OMNI_USE_VERTEX=1
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# === Google Cloud identity (keyless on Vercel) ===
# Set `wif` in Vercel production/preview. Leave unset for local ADC (`gcloud
# auth application-default login`) and for workloads with ambient GCP identity.
GCP_AUTH_MODE=wif
GCP_PROJECT_ID=ais-project-for-gcp
GCP_PROJECT_NUMBER=303288602776
GCP_SERVICE_ACCOUNT_EMAIL=aistudio-media-sa@ais-project-for-gcp.iam.gserviceaccount.com
GCP_WORKLOAD_IDENTITY_POOL_ID=vercel-pool
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel-provider

# === Database — Cloud SQL for PostgreSQL ===
# Keep `railway` until the final maintenance-window snapshot is imported, then
# change to `cloud-sql` and redeploy.
DATABASE_BACKEND=railway
# The Node.js connector creates an encrypted connection and obtains a short-lived
# IAM database token. Do not add a service-account JSON key to Vercel.
CLOUD_SQL_INSTANCE_CONNECTION_NAME=ais-project-for-gcp:us-central1:aistudio-db
CLOUD_SQL_IAM_AUTH=1
DB_NAME=aistudio
# Optional override. IAM defaults to GCP_SERVICE_ACCOUNT_EMAIL without the
# `.gserviceaccount.com` suffix.
DB_USER=
DB_POOL_MAX=2
DB_IDLE_TIMEOUT_MS=5000
DB_CONNECT_TIMEOUT_MS=10000

# Temporary Railway source/rollback path. Remove from Vercel after the Cloud SQL
# cutover has been stable for seven days. Migration scripts also read this value.
DATABASE_URL=

# === Auth ===
# Secret used to sign session cookies. Generate one: `openssl rand -hex 32`
AUTH_SECRET=

# Optional: set to "1" to run the app in MOCK mode (no real API calls),
# useful for previewing the UI before keys are configured.
MOCK_GENERATION=0

# === Media — Google Cloud Storage ===
# Keep `s3` until `migrate:media:gcp -- --verify-only` reports zero missing or
# different objects, then change to `gcs` and redeploy.
MEDIA_BACKEND=s3
GCP_MEDIA_BUCKET=aistudio-media-bucket
# Set after the Cloud CDN HTTPS hostname is ready. `/api/media/*` responds with
# a 307 redirect to this origin, so media bytes no longer traverse Vercel.
GCP_MEDIA_CDN_URL=
# Temporary migration rollback only. Requires AWS_* credentials and reads from
# S3 when an object is missing in GCS. Disable after migration verification.
GCS_MIGRATION_READ_FALLBACK=0
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === Higgsfield–NBP parity (experimental enhancements, all default to previous behavior) ===
# Structured shot-spec assembly: role-aware reference headers + framing coda for wide ARs.
# PROMPT_SHOT_SPEC=1
# Fallback role detection for uploads when not inferable from prompt text.
# PROMPT_ROLE_DETECT=1
# Composite best-of-N judge: scores identity + prominence + sharpness with floor selection.
# JUDGE_COMPOSITE=1
# Classical sharpen-only post-processing on the winning candidate (~110ms, fail-open).
# POST_CRISPEN=1
# Render one resolution step up, downsample to requested size (highest prominence, scene risk).
# SUPERSAMPLE=1
# Client reference longest-side cap for Vercel budget ladder (default: 2048).
# NEXT_PUBLIC_REF_MAX_DIM=2048
